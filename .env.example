# LLM Provider (required at runtime)
# Supported: openai, anthropic, gemini
LLM_PROVIDER=openai

# Default model per provider (optional — falls back to sensible defaults)
# OpenAI default:    gpt-5-mini
# Anthropic default: claude-4.6-sonnet
# Gemini default:    gemini-2.5-flash
LLM_MODEL=gemini-2.5-flash

# Cheaper model for summaries and follow-up suggestions (optional)
# OpenAI default: gpt-4o-mini | Anthropic default: claude-haiku-4-5 | Gemini default: gemini-2.5-flash
LLM_CHEAP_MODEL=gemini-2.5-flash

# API Keys — only the key for your chosen LLM_PROVIDER is required
OPENAI_API_KEY=apikey
ANTHROPIC_API_KEY=apikey
GOOGLE_API_KEY=apikey

# MongoDB (required — stores chat rooms and messages)
# Note: special characters in the password must be URL-encoded (e.g. "@" -> "%40")
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=unspoken

# Rate limiting (optional — defaults: 10 requests / 60000ms per IP)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Upstash Redis (for production rate limiting — replaces in-memory store)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Langfuse observability (optional — traces are skipped when keys are absent)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com